{
  "name": "perry-code-context",
  "displayName": "Perry Code Context",
  "description": "Inline code intelligence showing references, Git history, tests, and ownership.",
  "version": "0.1.3",
  "publisher": "kitarpgaruna",
  "icon": "media/perry-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pratik-anurag/perry.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "code intelligence",
    "codelens",
    "references",
    "git",
    "codeowners",
    "tests"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Perry can load its commands in untrusted workspaces, but code intelligence, Git context, file watching, and test discovery require a trusted workspace."
    }
  },
  "activationEvents": [
    "onCommand:perry.start",
    "onCommand:perry.stop",
    "onCommand:perry.refresh",
    "onCommand:perry.showDetails",
    "onCommand:perry.toggle",
    "onCommand:perry.showDiagnostics",
    "onCommand:perry.revealReferences",
    "onCommand:perry.openTestFile"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "package:check": "vsce ls",
    "release:local": "npm run compile && vsce package --no-dependencies",
    "install:local": "node scripts/install-local-vsix.js",
    "test": "npm run compile && node --test out/test/*.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  },
  "contributes": {
    "commands": [
      {
        "command": "perry.start",
        "title": "Perry: Start"
      },
      {
        "command": "perry.stop",
        "title": "Perry: Stop"
      },
      {
        "command": "perry.refresh",
        "title": "Perry: Refresh"
      },
      {
        "command": "perry.showDetails",
        "title": "Perry: Show Details"
      },
      {
        "command": "perry.toggle",
        "title": "Perry: Toggle"
      },
      {
        "command": "perry.showDiagnostics",
        "title": "Perry: Show Diagnostics"
      }
    ],
    "configuration": {
      "title": "Perry",
      "properties": {
        "perry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Perry inline annotations after Perry has been manually started."
        },
        "perry.showInlineContext": {
          "type": "boolean",
          "default": false,
          "description": "Deprecated. Inline decoration blocks are disabled because VS Code decorations do not reserve editor space."
        },
        "perry.showDetailsLens": {
          "type": "boolean",
          "default": true,
          "description": "Show a non-overlapping CodeLens summary for opening the details panel."
        },
        "perry.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Show a rich Perry hover card when hovering symbols."
        },
        "perry.enableSymbolLinks": {
          "type": "boolean",
          "default": true,
          "description": "Make symbol names clickable with Ctrl/Cmd-click where VS Code document links are available."
        },
        "perry.maxSymbolsPerFile": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "Maximum number of symbols to annotate in a single file."
        },
        "perry.enableGit": {
          "type": "boolean",
          "default": true,
          "description": "Include local Git blame or log context."
        },
        "perry.enableReferences": {
          "type": "boolean",
          "default": true,
          "description": "Include reference counts from the active language server."
        },
        "perry.enableTests": {
          "type": "boolean",
          "default": true,
          "description": "Search workspace test files for related tests."
        },
        "perry.enableOwners": {
          "type": "boolean",
          "default": true,
          "description": "Match files against local CODEOWNERS rules."
        }
      }
    }
  }
}
